# ==========================================
# 应用核心配置
# ==========================================

# 运行环境 (development | production)
VITE_APP_ENV=development


# 应用显示名称 (用于页面标题和浏览器标签)
VITE_APP_TITLE=weiShaoY

# 应用描述信息 (用于 SEO 和社交媒体分享)
VITE_APP_DESC=代码改变世界 !


# ==========================================
# 样式与 UI 配置
# ==========================================

# 应用全局字体家族 (需在 CSS 中定义对应字体)
VITE_APP_FONT_FAMILY=shouJinTi

# 应用内图标名称的前缀 (用于统一管理Svg图标命名)
VITE_APP_ICON_PREFIX=icon










